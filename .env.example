# AWS
AWS_REGION=eu-west-3
S3_BUCKET_NAME=teads-recruitment-analytics-raw

# GCP / BigQuery
GCP_PROJECT_ID=your-gcp-project-id
BQ_RAW_DATASET=raw_greenhouse
BQ_STG_DATASET=stg_greenhouse
BQ_CORE_DATASET=core_greenhouse
BQ_MARTS_DATASET=marts_recruitment

# Local data
LOCAL_DATA_DIR=data

# Mock API dataset profile: original or large
MOCK_DATASET_PROFILE=large

# Local-only admin workflow demo
APP_ENV=local
ENABLE_ADMIN_CHANGE_WORKFLOW=false
ADMIN_ALLOWED_EMAILS=admin@example.com,manager@example.com
ADMIN_DEMO_PASSWORD=change-me-locally
ADMIN_DEMO_OTP=123456
ADMIN_REQUIRE_OTP=true
ADMIN_ROLE_MAP_JSON={"admin@example.com":"super_admin","manager@example.com":"hr_manager"}
ALLOW_HR_MANAGER_APPLY=false
ALLOW_BUSINESS_MANAGER_APPLY=false
ADMIN_MAX_BATCH_SIZE=500
ADMIN_STOP_ON_ERROR_RATE=0.05
ADMIN_API_SLEEP_SECONDS=0.1
ALLOW_PROD_PIPELINE_TRIGGER=false

# Supabase SaaS-like operational source
USE_SUPABASE_OPERATIONAL_SOURCE=false
ENABLE_SUPABASE_AUTH=false
ALLOW_SUPABASE_PROD_APPLY=false
ALLOW_SUPABASE_PIPELINE_TRIGGER=false
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AUTH_PROVIDER=google
SUPABASE_REDIRECT_URL=
SUPABASE_ALLOWED_EMAIL_DOMAIN=
SUPABASE_BOOTSTRAP_ADMIN_EMAIL=

# Streamlit admin -> Airflow REST API trigger for the Supabase demo pipeline
ENABLE_ADMIN_AIRFLOW_TRIGGER=false
AIRFLOW_API_BASE_URL=http://localhost:8080
AIRFLOW_DAG_ID=supabase_recruitment_analytics_demo_pipeline
AIRFLOW_USERNAME=
AIRFLOW_PASSWORD=
AIRFLOW_BEARER_TOKEN=

# Future real Greenhouse integration guardrails
MOCK_API_BASE_URL=http://127.0.0.1:8000
REAL_GREENHOUSE_API_BASE_URL=
REAL_GREENHOUSE_API_ENABLED=false
GREENHOUSE_API_KEY=
